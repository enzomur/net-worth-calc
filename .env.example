# Net Worth Calculator Environment Variables
# Copy this file to .env.local for development

# Application name displayed in the UI
NEXT_PUBLIC_APP_NAME=Net Worth Educator

# Application version
NEXT_PUBLIC_APP_VERSION=0.1.0

# Enable localStorage encryption by default (true/false)
NEXT_PUBLIC_ENABLE_ENCRYPTION=true

# Maximum number of assets a user can add
NEXT_PUBLIC_MAX_ASSETS=1000

# Maximum number of liabilities a user can add
NEXT_PUBLIC_MAX_LIABILITIES=1000
